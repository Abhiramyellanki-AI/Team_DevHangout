// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: userId (string)
// Fields:
//   - email: string (required)
//   - createdAt: string (required)
//
// Collection: documents
// Document ID: documentId (string)
// Fields:
//   - userId: string (required)
//   - fileName: string (required)
//   - fileType: string (required, enum: ["pdf", "xlsx"])
//   - uploadDate: string (required)
//   - status: string (required, enum: ["uploaded", "processing", "completed", "error"])
//
// Collection: documents/{documentId}/extracted_data
// Document ID: dataId (string)
// Fields:
//   - documentId: string (required)
//   - category: string (required, enum: ["hardware", "software"])
//   - parameter: string (required)
//   - value: string (required)
//   - confidenceScore: number (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "abhiramyellanki44@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.createdAt is string;
    }

    function isValidDocument(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.fileName is string && data.fileName.size() > 0 && data.fileName.size() < 255 &&
             data.fileType in ["pdf", "xlsx"] &&
             data.uploadDate is string &&
             data.status in ["uploaded", "processing", "completed", "error"];
    }

    function isValidExtractedData(data) {
      return data.documentId is string &&
             data.category in ["hardware", "software"] &&
             data.parameter is string && data.parameter.size() > 0 && data.parameter.size() < 100 &&
             data.value is string && data.value.size() > 0 && data.value.size() < 1000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && hasOnlyAllowedFields(['email', 'createdAt', 'role']);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && hasOnlyAllowedFields(['email', 'createdAt', 'role']) && request.resource.data.role == resource.data.role;
    }

    match /documents/{documentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidDocument(request.resource.data) && hasRequiredFields(['userId', 'fileName', 'fileType', 'uploadDate', 'status']);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidDocument(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());

      match /extracted_data/{dataId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/documents/$(documentId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isAuthenticated() && (get(/databases/$(database)/documents/documents/$(documentId)).data.userId == request.auth.uid || isAdmin()) && isValidExtractedData(request.resource.data);
        allow update: if isAuthenticated() && (get(/databases/$(database)/documents/documents/$(documentId)).data.userId == request.auth.uid || isAdmin()) && isValidExtractedData(request.resource.data);
        allow delete: if isAuthenticated() && (get(/databases/$(database)/documents/documents/$(documentId)).data.userId == request.auth.uid || isAdmin());
      }
    }
  }
}
